# Ignore everything
*

# Allow directories
!*/

# Allow specific files in the root
!.gitignore
!README.md
!LICENSE
!gradlew
!gradlew.bat

# Allow GitHub Action workflows
!.github/
!.github/**

# Allow Gradle wrapper and configuration
!gradle/
!gradle/**

# Allow sample projects
!samples/
!samples/**

# Exceptions for common build artifacts and local settings if they were somehow unignored
.gradle/
build/
bin/
out/
.idea/
*.iml
.vscode/
.DS_Store
Thumbs.db
*.swp
*~
.env
*.local
